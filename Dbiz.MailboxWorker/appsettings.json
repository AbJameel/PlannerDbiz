      "https://graph.microsoft.com/.default"
    ]
  },
  "PlannerApi": {
    "Enabled": false,
    "BaseUrl": "https://your-planner-api-base-url",
    "CreatePlannerPath": "/api/planner/mail/create",
    "ApiKey": "",
    "ApiKeyHeaderName": "x-api-key",
    "BearerToken": "",
