    "AttachmentDownloadFolderPath": "Data/Attachments",
    "MaxAttachmentTextLength": 20000,
    "MaxBodyTextLength": 20000,
    "FallbackMailJsonPath": "Models/output_mail.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
